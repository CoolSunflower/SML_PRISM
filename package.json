{
  "name": "sml-backend",
  "version": "1.0.0",
  "description": "Backend for Social Media Listening",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch --runInBand",
    "test:workers": "jest test/classificationWorkerPool.test.js --runInBand --detectOpenHandles",
    "test:integration": "jest test/kwatch-integration.test.js --runInBand --detectOpenHandles --forceExit",
    "migrate:fetch": "node scripts/1-fetch-raw-data.js",
    "migrate:test": "node scripts/2-test-classification.js",
    "migrate:push": "node scripts/3-push-to-database.js"
  },
  "keywords": [
    "azure",
    "cosmos-db",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/cosmos": "^4.9.0",
    "@huggingface/transformers": "^3.8.1",
    "@mozilla/readability": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "fasttext.js": "^1.1.4",
    "franc": "^6.2.0",
    "jsdom": "^28.1.0",
    "langdetect": "^0.2.1",
    "natural": "^8.1.1",
    "onnxruntime-node": "1.21.0",
    "rss-parser": "^3.13.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "services/**/*.js",
      "workers/**/*.js",
      "utils/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "overrides": {
    "onnxruntime-node": "1.21.0"
  }
}
